# Firebase Web App config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Lista de e-mails admins (separados por vírgula)
VITE_ADMIN_EMAILS=admin@empresa.com

# Logo externa opcional (URL completa, ex: https://cdn.seudominio.com/logo.png)
VITE_BRAND_LOGO_URL=https://pin.it/gG80yybQ1
# Backend de pagamentos (Vercel Functions)
# Em produção no Vercel, pode deixar vazio para usar '/api' automaticamente.
# Exemplo externo: https://seu-app.vercel.app/api
VITE_PAYMENT_API_BASE_URL=/api
